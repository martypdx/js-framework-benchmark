  },
  "devDependencies": {
    "rollup": "^0.67.3",
    "rollup-plugin-azoth": "^0.4.1",
    "rollup-plugin-cleanup": "^3.0.0",
    "rollup-plugin-commonjs": "^9.2.0",
    "rollup-plugin-node-resolve": "^3.4.0"
  },
  "dependencies": {
    "azoth": "^0.1.0"
