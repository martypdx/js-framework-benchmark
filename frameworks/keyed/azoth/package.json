{
  "name": "js-framework-benchmark-azoth",
  "version": "1.0.0",
  "description": "Boilerplate Benchmark for Azoth",
  "scripts": {
    "start": "rollup -c -w",
    "build-prod": "rollup -c --environment production"
  },
  "keywords": [
    "azoth"
  ],
  "js-framework-benchmark": {
    "frameworkVersionFromPackage": "azoth",
    "customURL": "/dist"
  },
